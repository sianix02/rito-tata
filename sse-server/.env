# ── Database (match your Laragon settings) ───────────────────
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=ritotata_db

# ── Server ────────────────────────────────────────────────────
# Use a different port from Laragon (80/443)
PORT=3001

# ── Allowed origin (your Laragon site URL) ────────────────────
# No trailing slash
CORS_ORIGIN=http://rito-tata.test

# ── How often to poll the DB for changes (milliseconds) ───────
POLL_INTERVAL=3000
